<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        id="statusLegendDialog"
        title="상태 정의"
        contentWidth="22rem"
        draggable="true"
        resizable="true">
        <content>
            <VBox
                items="{tank>/statusLegendItems}"
                class="tankStatusDialogContent sapUiSmallMargin">
                <items>
                    <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                        <core:HTML
                            preferDOM="true"
                            sanitizeContent="false"
                            content="{tank>iconHtml}"/>
                        <Text text="{tank>label}" class="sapUiSmallMarginBegin"/>
                    </HBox>
                </items>
            </VBox>
        </content>
        <beginButton>
            <Button text="닫기" press="onStatusLegendClose"/>
        </beginButton>
    </Dialog>
</core:FragmentDefinition>
